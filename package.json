{
  "name": "tessera",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Tessera — zoomable cloud monitoring platform. Hexwall is the EKS leaf renderer.",
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/web"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "build": "npm run build:web && npm run build:server",
    "build:web": "vite build packages/web",
    "build:server": "node scripts/build-server.mjs",
    "start:server": "node packages/server/dist/server.mjs",
    "test:e2e": "npm run build:web && playwright test",
    "verify": "npm run typecheck && npm run lint && npm test && npm run build && npm run test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "@vitest/coverage-v8": "^2.1.3",
    "esbuild": "^0.24.0",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.11.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.10.0",
    "vite": "^5.4.9",
    "vite-tsconfig-paths": "^5.0.1",
    "vitest": "^2.1.3"
  }
}
